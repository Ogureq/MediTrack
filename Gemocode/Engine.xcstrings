    "review.disclaimer": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Gemocode provides educational information only. It is not a medical device, does not provide a diagnosis, and is not a substitute for professional medical advice. Always consult a qualified healthcare professional about your results and before making any health decisions."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Gemocode предоставляет только справочную информацию. Приложение не является медицинским изделием, не устанавливает диагноз и не заменяет консультацию квалифицированного специалиста здравоохранения. Всегда консультируйтесь с квалифицированным специалистом здравоохранения по поводу своих результатов и перед принятием любых решений, касающихся здоровья."
          }
        }
      }
    },
