    },
    "finding.lab.critical.title": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ is at a critical level"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ — критический уровень"
          }
        }
      }
    },
    "finding.lab.detail": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Latest value %1$@ (typical range %2$@). %3$@"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Последнее значение: %1$@ (типичный диапазон: %2$@). %3$@"
          }
        }
      }
    },
    "finding.lab.critical.recommendation": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Contact your healthcare provider promptly to review this result."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Как можно скорее обратитесь к врачу, чтобы обсудить этот результат."
          }
        }
      }
    },
    "finding.lab.low.title": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ is below its reference range"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ ниже референсного диапазона"
          }
        }
      }
    },
    "finding.lab.high.title": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ is above its reference range"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ выше референсного диапазона"
          }
        }
      }
    },
    "finding.lab.attention.recommendation": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Worth discussing with your doctor at your next visit."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Стоит обсудить с врачом на следующем приёме."
          }
        }
      }
    },
    "trend.lab.improving": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ changed %2$@ over %3$lld entries and is moving toward its reference range."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ изменился на %2$@ за %3$lld записей и приближается к референсному диапазону."
          }
        }
      }
    },
    "trend.lab.worsening": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ changed %2$@ over %3$lld entries and is moving away from its reference range."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ изменился на %2$@ за %3$lld записей и отдаляется от референсного диапазона."
          }
        }
      }
    },
    "trend.lab.stable": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ is stable across %2$lld entries."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ стабилен на протяжении %2$lld записей."
          }
        }
      }
    },
    "trend.lab.risingFalling": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ changed %2$@ over %3$lld entries."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ изменился на %2$@ за %3$lld записей."
          }
        }
      }
    },
    "finding.trend.lab.worsening.title": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ is trending away from its range"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ демонстрирует отклонение от диапазона"
          }
        }
      }
    },
    "finding.trend.recommendation": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Keep tracking this value and mention the trend to your doctor."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Продолжайте отслеживать этот показатель и обсудите динамику с врачом."
          }
        }
      }
    },
    "finding.cholesterolRatio.high.title": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Cholesterol ratio is high"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Повышено соотношение холестерина"
          }
        }
      }
    },
    "finding.cholesterolRatio.high.detail": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your total-to-HDL cholesterol ratio is %@ (target below 5, ideal below 3.5). This ratio is a useful indicator of cardiovascular risk."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Соотношение общего холестерина к ЛПВП составляет %@ (целевое значение — ниже 5, оптимальное — ниже 3,5). Этот показатель полезен для оценки сердечно-сосудистого риска."
          }
        }
      }
    },
    "finding.cholesterolRatio.high.recommendation": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Discuss lipid management with your doctor."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Обсудите с врачом коррекцию липидного профиля."
          }
        }
      }
    },
    "finding.cholesterolRatio.normal.title": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Cholesterol ratio: %@"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Соотношение холестерина: %@"
          }
        }
      }
    },
    "finding.cholesterolRatio.ideal.detail": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A total-to-HDL cholesterol ratio below 3.5 is considered ideal."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Соотношение общего холестерина к ЛПВП ниже 3,5 считается оптимальным."
          }
        }
      }
    },
    "finding.cholesterolRatio.withinTarget.detail": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your total-to-HDL cholesterol ratio is within the generally recommended target of below 5."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Ваше соотношение общего холестерина к ЛПВП находится в пределах рекомендуемого целевого значения — ниже 5."
          }
        }
      }
    },
    "finding.nonHDL.title": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Non-HDL cholesterol is high"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Повышен холестерин не-ЛПВП"
          }
        }
      }
    },
    "finding.nonHDL.detail": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Non-HDL cholesterol (total minus HDL) is %lld mg/dL; below 130 mg/dL is generally recommended. It captures all cholesterol carried by potentially artery-clogging particles."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Холестерин не-ЛПВП (общий минус ЛПВП) составляет %lld мг/дл; рекомендуется значение ниже 130 мг/дл. Этот показатель учитывает весь холестерин, переносимый потенциально атерогенными частицами."
          }
        }
      }
    },
    "finding.nonHDL.recommendation": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Worth reviewing with your doctor alongside your full lipid panel."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Стоит обсудить с врачом вместе с полным липидным профилем."
          }
        }
      }
    },
    "finding.bp.crisis.title": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Blood pressure at crisis level"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Артериальное давление на уровне криза"
          }
        }
      }
    },
    "finding.bp.stage2.title": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Blood pressure in Stage 2 hypertension range"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Артериальное давление соответствует гипертонии 2 степени"
          }
        }
      }
    },
    "finding.bp.stage1.title": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Blood pressure in Stage 1 hypertension range"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Артериальное давление соответствует гипертонии 1 степени"
          }
        }
      }
    },
    "finding.bp.elevated.title": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Blood pressure slightly elevated"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Артериальное давление слегка повышено"
          }
        }
      }
    },
    "finding.bp.normal.title": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Blood pressure is normal"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Артериальное давление в норме"
          }
        }
      }
    },
    "finding.bp.detail": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Latest reading %1$@ falls in the %2$@ category."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Последнее измерение %1$@ соответствует категории «%2$@»."
          }
        }
      }
    },
    "finding.bp.elevated.detail": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Latest reading %@ is above normal but below hypertension thresholds."
