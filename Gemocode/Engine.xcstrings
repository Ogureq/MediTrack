    "interactionSeverity.major": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Major"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Серьёзное"
          }
        }
      }
    },
    "medicationInteractions.disclaimer": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This is an educational check against a small list of well-known interactions — it is not exhaustive. The absence of a warning does not mean a combination is safe. Always confirm your full medication list with your pharmacist or doctor."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Это образовательная проверка по небольшому списку хорошо изученных взаимодействий — она не является исчерпывающей. Отсутствие предупреждения не означает, что комбинация безопасна. Всегда уточняйте полный список ваших препаратов у фармацевта или врача."
          }
        }
      }
    },
    "interaction.warfarin_nsaid.explanation": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Combining warfarin with NSAIDs meaningfully increases the risk of serious bleeding, including gastrointestinal bleeding."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Сочетание варфарина с НПВП существенно повышает риск серьёзных кровотечений, включая желудочно-кишечные."
          }
        }
      }
    },
    "interaction.warfarin_nsaid.recommendation": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Ask your doctor about a safer pain reliever such as acetaminophen."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Спросите врача о более безопасном обезболивающем, например парацетамоле."
          }
        }
      }
    },
    "interaction.warfarin_aspirin.explanation": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Warfarin plus aspirin raises the risk of bleeding because both affect clotting."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Варфарин в сочетании с аспирином повышает риск кровотечения, поскольку оба препарата влияют на свёртываемость крови."
          }
        }
      }
    },
    "interaction.warfarin_aspirin.recommendation": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Only combine under a doctor's supervision."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Сочетайте эти препараты только под наблюдением врача."
          }
        }
      }
    },
    "interaction.warfarin_clopidogrel.explanation": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Two blood thinners together substantially increase bleeding risk."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Два антикоагулянта вместе существенно повышают риск кровотечения."
          }
        }
      }
    },
    "interaction.warfarin_clopidogrel.recommendation": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This combination should only be used when a doctor specifically directs it."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Эту комбинацию следует применять только по прямому указанию врача."
          }
        }
      }
    },
    "interaction.ssri_maoi.explanation": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "SSRIs/SNRIs with MAOIs can cause serotonin syndrome, a potentially dangerous reaction."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "СИОЗС/СИОЗСН в сочетании с ИМАО могут вызвать серотониновый синдром — потенциально опасную реакцию."
          }
        }
      }
    },
    "interaction.ssri_maoi.recommendation": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This combination is generally avoided; talk to your prescriber right away."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Такой комбинации обычно избегают; немедленно свяжитесь с врачом, выписавшим препарат."
          }
        }
      }
    },
    "interaction.ssri_tramadol.explanation": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Tramadol with an SSRI/SNRI raises the risk of serotonin syndrome and can lower the seizure threshold."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Трамадол в сочетании с СИОЗС/СИОЗСН повышает риск серотонинового синдрома и может снижать судорожный порог."
          }
        }
      }
    },
    "interaction.ssri_tramadol.recommendation": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Mention this pairing to your doctor or pharmacist."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Сообщите об этом сочетании врачу или фармацевту."
          }
        }
      }
    },
    "interaction.ssri_triptan.explanation": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Triptans with SSRIs/SNRIs can, uncommonly, contribute to serotonin syndrome."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Триптаны в сочетании с СИОЗС/СИОЗСН редко могут способствовать развитию серотонинового синдрома."
          }
        }
      }
    },
    "interaction.ssri_triptan.recommendation": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Usually manageable — review symptoms to watch for with your pharmacist."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Обычно это контролируемо — уточните у фармацевта, на какие симптомы обращать внимание."
          }
        }
      }
    },
    "interaction.tramadol_triptan.explanation": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Both increase serotonin activity, which can rarely lead to serotonin syndrome."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Оба препарата повышают серотониновую активность, что в редких случаях может привести к серотониновому синдрому."
          }
        }
      }
    },
    "interaction.tramadol_triptan.recommendation": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Discuss with your pharmacist if used together often."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Если вы часто принимаете их вместе, обсудите это с фармацевтом."
          }
        }
      }
    },
    "interaction.ace_inhibitor_potassium_sparing.explanation": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "ACE inhibitors with potassium-sparing diuretics can raise blood potassium to unsafe levels."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "ИАПФ в сочетании с калийсберегающими диуретиками могут повышать уровень калия в крови до небезопасных значений."
          }
        }
      }
    },
    "interaction.ace_inhibitor_potassium_sparing.recommendation": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your doctor may want to monitor your potassium and kidney function."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Врач может назначить контроль уровня калия и функции почек."
          }
        }
      }
    },
    "interaction.ace_inhibitor_potassium.explanation": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "ACE inhibitors plus potassium supplements can raise blood potassium."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "ИАПФ в сочетании с препаратами калия могут повышать уровень калия в крови."
          }
        }
      }
    },
    "interaction.ace_inhibitor_potassium.recommendation": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Have your potassium checked as your doctor advises."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Проверяйте уровень калия по рекомендации врача."
          }
        }
      }
    },
    "interaction.ace_inhibitor_arb.explanation": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Combining an ACE inhibitor and an ARB increases the risk of high potassium and kidney strain with little added benefit."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Сочетание ИАПФ и БРА повышает риск избытка калия и нагрузки на почки, практически не давая дополнительной пользы."
          }
        }
      }
    },
    "interaction.ace_inhibitor_arb.recommendation": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This combination is usually avoided; confirm with your doctor."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Такой комбинации обычно избегают; уточните это у врача."
          }
        }
      }
    },
    "interaction.ace_inhibitor_nsaid.explanation": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "NSAIDs can reduce the effect of ACE inhibitors and, together, may strain the kidneys."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "НПВП могут снижать эффективность ИАПФ, а вместе они могут создавать нагрузку на почки."
          }
        }
      }
    },
    "interaction.ace_inhibitor_nsaid.recommendation": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Limit NSAID use and discuss alternatives with your doctor."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Ограничьте приём НПВП и обсудите альтернативы с врачом."
          }
        }
      }
    },
    "interaction.statin_grapefruit.explanation": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Grapefruit can raise levels of some statins (especially simvastatin and atorvastatin), increasing the risk of muscle problems."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Грейпфрут может повышать уровень некоторых статинов (особенно симвастатина и аторвастатина), увеличивая риск проблем с мышцами."
          }
        }
      }
    },
    "interaction.statin_grapefruit.recommendation": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Ask your pharmacist whether your specific statin is affected."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Спросите фармацевта, влияет ли грейпфрут на ваш конкретный статин."
          }
        }
      }
    },
    "interaction.pde5_nitrate.explanation": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "PDE5 inhibitors (e.g. sildenafil) with nitrates can cause a dangerous drop in blood pressure."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Ингибиторы ФДЭ5 (например, силденафил) в сочетании с нитратами могут вызвать опасное падение артериального давления."
          }
        }
      }
    },
    "interaction.pde5_nitrate.recommendation": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This combination should be avoided — tell any prescriber you take both."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Этой комбинации следует избегать — сообщайте любому назначающему врачу, что принимаете оба препарата."
          }
        }
      }
    },
    "interaction.opioid_benzodiazepine.explanation": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Opioids with benzodiazepines can cause profound sedation and dangerous slowing of breathing."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Опиоиды в сочетании с бензодиазепинами могут вызывать глубокую седацию и опасное угнетение дыхания."
          }
        }
      }
    },
    "interaction.opioid_benzodiazepine.recommendation": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Use together only under close medical supervision."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Принимайте вместе только под тщательным наблюдением врача."
          }
        }
      }
    },
    "interaction.digoxin_amiodarone.explanation": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Amiodarone can raise digoxin levels and lead to toxicity."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Амиодарон может повышать уровень дигоксина и приводить к его токсическому действию."
          }
        }
      }
    },
    "interaction.digoxin_amiodarone.recommendation": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your doctor may reduce your digoxin dose and monitor levels."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Врач может снизить дозу дигоксина и контролировать его уровень."
          }
        }
      }
    },
    "interaction.methotrexate_nsaid.explanation": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "NSAIDs can raise methotrexate levels and increase toxicity, especially at higher methotrexate doses."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "НПВП могут повышать уровень метотрексата и усиливать его токсичность, особенно при высоких дозах метотрексата."
          }
        }
      }
    },
    "interaction.methotrexate_nsaid.recommendation": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Confirm any pain reliever with the doctor managing your methotrexate."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Согласовывайте любое обезболивающее с врачом, который назначил вам метотрексат."
          }
        }
      }
    },
    "interaction.lithium_nsaid.explanation": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "NSAIDs can raise lithium levels and increase the risk of lithium toxicity."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "НПВП могут повышать уровень лития и увеличивать риск его токсического действия."
          }
        }
      }
    },
    "interaction.lithium_nsaid.recommendation": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Prefer acetaminophen and have lithium levels monitored."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Предпочтительнее использовать парацетамол и контролировать уровень лития."
          }
        }
      }
    },
    "interaction.clopidogrel_ppi.explanation": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Some PPIs (especially omeprazole) can reduce clopidogrel's anti-clotting effect."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Некоторые ИПП (особенно омепразол) могут снижать антиагрегантный эффект клопидогреля."
          }
        }
      }
    },
    "interaction.clopidogrel_ppi.recommendation": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Ask your pharmacist about a PPI that interacts less, if one is needed."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Если ИПП необходим, спросите фармацевта о варианте с меньшим взаимодействием."
          }
        }
      }
    },
    "interaction.aspirin_nsaid.explanation": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Taking aspirin with other NSAIDs increases stomach and bleeding risk and may blunt aspirin's heart benefit."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Приём аспирина вместе с другими НПВП повышает риск проблем с желудком и кровотечений, а также может снижать кардиопротективный эффект аспирина."
          }
        }
      }
    },
    "interaction.aspirin_nsaid.recommendation": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Space doses or ask your pharmacist about the safest option."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Разнесите приём препаратов по времени или спросите фармацевта о самом безопасном варианте."
          }
        }
      }
    },
    "interaction.statin_amiodarone.explanation": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Amiodarone can raise levels of some statins, increasing the risk of muscle injury."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Амиодарон может повышать уровень некоторых статинов, увеличивая риск повреждения мышц."
          }
        }
      }
    },
    "interaction.statin_amiodarone.recommendation": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your doctor may cap the statin dose; report muscle pain."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Врач может ограничить дозу статина; сообщайте о мышечной боли."
          }
        }
      }
    },
