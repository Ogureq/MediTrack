    "lab.hemoglobin.name": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Hemoglobin"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Гемоглобин"
          }
        }
      }
    },
    "lab.hemoglobin.shortName": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Hgb"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Hb"
          }
        }
      }
    },
    "lab.hemoglobin.about": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Hemoglobin is the protein in red blood cells that carries oxygen from the lungs to the rest of the body."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Гемоглобин — белок эритроцитов, который переносит кислород от лёгких к остальным тканям организма."
          }
        }
      }
    },
    "lab.hemoglobin.lowMeaning": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A low value can accompany anemia, recent blood loss, low iron, or pregnancy. Fatigue or shortness of breath alongside a low value is worth discussing with a clinician."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Низкое значение может сопровождать анемию, недавнюю кровопотерю, дефицит железа или беременность. Если низкое значение сопровождается усталостью или одышкой, стоит обсудить это с врачом."
          }
        }
      }
    },
    "lab.hemoglobin.highMeaning": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A high value may reflect dehydration, living at high altitude, or smoking. Persistently high values are worth reviewing with a clinician."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Высокое значение может быть связано с обезвоживанием, проживанием на большой высоте или курением. Стабильно высокие значения стоит обсудить с врачом."
          }
        }
      }
    },
    "lab.hematocrit.name": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Hematocrit"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Гематокрит"
          }
        }
      }
    },
    "lab.hematocrit.shortName": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Hct"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Ht"
          }
        }
      }
    },
    "lab.hematocrit.about": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Hematocrit is the percentage of your blood volume made up of red blood cells."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Гематокрит — доля объёма крови, приходящаяся на эритроциты."
          }
        }
      }
    },
    "lab.hematocrit.lowMeaning": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A low value often mirrors anemia, blood loss, or overhydration. Consider discussing with a clinician if it persists or comes with fatigue."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Низкое значение часто отражает анемию, кровопотерю или избыточную гидратацию. Если оно сохраняется или сопровождается усталостью, стоит обсудить это с врачом."
          }
        }
      }
    },
    "lab.hematocrit.highMeaning": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A high value is commonly caused by dehydration; it can also occur at high altitude. Persistent elevation is worth a clinician's review."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Высокое значение чаще всего связано с обезвоживанием; также может встречаться на большой высоте. Стойкое повышение стоит обсудить с врачом."
          }
        }
      }
    },
    "lab.redBloodCells.name": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Red Blood Cell Count"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Эритроциты"
          }
        }
      }
    },
    "lab.redBloodCells.shortName": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "RBC"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "RBC"
          }
        }
      }
    },
    "lab.redBloodCells.about": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This measures the number of red blood cells, which carry oxygen throughout the body."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Показатель отражает количество эритроцитов — клеток, переносящих кислород по организму."
          }
        }
      }
    },
    "lab.redBloodCells.lowMeaning": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A low count can accompany anemia, blood loss, or nutritional shortfalls such as low iron, B12, or folate. Discuss with a clinician if it persists."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Низкое количество может сопровождать анемию, кровопотерю или дефицит питательных веществ, таких как железо, B12 или фолиевая кислота. Если оно сохраняется, обсудите это с врачом."
          }
        }
      }
    },
    "lab.redBloodCells.highMeaning": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A high count may reflect dehydration, smoking, or high-altitude living. Persistent elevation is worth reviewing with a clinician."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Высокое количество может быть связано с обезвоживанием, курением или проживанием на большой высоте. Стойкое повышение стоит обсудить с врачом."
          }
        }
      }
    },
    "lab.whiteBloodCells.name": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "White Blood Cell Count"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Лейкоциты"
          }
        }
      }
    },
    "lab.whiteBloodCells.shortName": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "WBC"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "WBC"
          }
        }
      }
    },
    "lab.whiteBloodCells.about": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "White blood cells are part of the immune system and help the body fight infection."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Лейкоциты — часть иммунной системы, которая помогает организму бороться с инфекциями."
          }
        }
      }
    },
    "lab.whiteBloodCells.lowMeaning": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A low count can follow some viral infections, certain medications, or immune conditions. A very low count or frequent infections should be discussed with a clinician."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Низкое количество может встречаться после некоторых вирусных инфекций, на фоне определённых препаратов или иммунных нарушений. Очень низкое количество или частые инфекции стоит обсудить с врачом."
          }
        }
      }
    },
    "lab.whiteBloodCells.highMeaning": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A high count often reflects the body responding to infection, inflammation, stress, or recent exercise. Persistent or very high values warrant a clinician's review."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Высокое количество часто отражает реакцию организма на инфекцию, воспаление, стресс или недавнюю физическую нагрузку. Стойкое или очень высокое значение требует консультации врача."
          }
        }
      }
    },
    "lab.platelets.name": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Platelet Count"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Тромбоциты"
          }
        }
      }
    },
    "lab.platelets.shortName": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "PLT"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "PLT"
          }
        }
      }
    },
    "lab.platelets.about": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Platelets are small cell fragments that help blood clot and stop bleeding."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Тромбоциты — небольшие клеточные фрагменты, которые участвуют в свёртывании крови и остановке кровотечений."
          }
        }
      }
    },
    "lab.platelets.lowMeaning": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A low count can be linked to certain infections, medications, or immune conditions and may increase bruising or bleeding. Discuss notably low values with a clinician."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Низкое количество может быть связано с некоторыми инфекциями, препаратами или иммунными нарушениями и повышать склонность к синякам или кровотечениям. Заметно низкие значения стоит обсудить с врачом."
          }
        }
      }
    },
    "lab.platelets.highMeaning": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A high count can occur temporarily after infection, inflammation, or iron deficiency. Persistent elevation is worth reviewing with a clinician."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Временное повышение может возникать после инфекции, воспаления или при дефиците железа. Стойкое повышение стоит обсудить с врачом."
          }
        }
      }
    },
    "lab.mcv.name": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Mean Corpuscular Volume"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Средний объём эритроцита"
          }
        }
      }
    },
    "lab.mcv.shortName": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "MCV"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "MCV"
          }
        }
      }
    },
    "lab.mcv.about": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "MCV describes the average size of your red blood cells and helps classify anemias."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "MCV отражает средний размер эритроцитов и помогает классифицировать виды анемии."
          }
        }
      }
    },
    "lab.mcv.lowMeaning": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Smaller-than-average red cells (low MCV) are commonly associated with iron deficiency or certain inherited traits. Discuss with a clinician if paired with anemia."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Эритроциты меньше среднего размера (низкий MCV) обычно связаны с дефицитом железа или некоторыми наследственными особенностями. При сочетании с анемией обсудите это с врачом."
          }
        }
      }
    },
    "lab.mcv.highMeaning": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Larger-than-average red cells (high MCV) can relate to low B12 or folate, some medications, or alcohol use. Consider reviewing with a clinician."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Эритроциты крупнее среднего размера (высокий MCV) могут быть связаны с дефицитом B12 или фолиевой кислоты, приёмом некоторых препаратов или употреблением алкоголя. Стоит обсудить это с врачом."
          }
        }
      }
    },
    "lab.mch.name": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Mean Corpuscular Hemoglobin"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Среднее содержание гемоглобина в эритроците"
          }
        }
      }
    },
    "lab.mch.shortName": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "MCH"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "MCH"
          }
        }
      }
    },
    "lab.mch.about": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "MCH is the average amount of hemoglobin contained in a single red blood cell."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "MCH — среднее количество гемоглобина в одном эритроците."
          }
        }
      }
    },
    "lab.mch.lowMeaning": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A low value means each red cell carries less hemoglobin on average, often alongside iron deficiency. Discuss with a clinician if anemia is also present."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Низкое значение означает, что в среднем каждый эритроцит содержит меньше гемоглобина, часто на фоне дефицита железа. При наличии анемии обсудите это с врачом."
          }
        }
      }
    },
    "lab.mch.highMeaning": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A high value can accompany larger red cells, such as with low B12 or folate. Consider reviewing with a clinician if it persists."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Высокое значение может сопровождать увеличенные эритроциты, например при дефиците B12 или фолиевой кислоты. Если оно сохраняется, стоит обсудить это с врачом."
          }
        }
      }
    },
    "lab.mchc.name": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Mean Corpuscular Hemoglobin Concentration"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Средняя концентрация гемоглобина в эритроците"
          }
        }
      }
    },
    "lab.mchc.shortName": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "MCHC"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "MCHC"
          }
        }
      }
    },
    "lab.mchc.about": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "MCHC is the concentration of hemoglobin within a given volume of red blood cells."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "MCHC — концентрация гемоглобина в заданном объёме эритроцитов."
          }
        }
      }
    },
    "lab.mchc.lowMeaning": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A low value can be seen with iron deficiency. It is usually interpreted together with other red-cell indices; discuss persistent findings with a clinician."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Низкое значение может встречаться при дефиците железа. Обычно оно оценивается вместе с другими эритроцитарными индексами; стойкие отклонения стоит обсудить с врачом."
          }
        }
      }
    },
    "lab.mchc.highMeaning": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A high value is less common and can occasionally reflect certain red-cell conditions or a lab artifact. Consider reviewing with a clinician."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Высокое значение встречается реже и иногда может отражать определённые особенности эритроцитов или лабораторный артефакт. Стоит обсудить это с врачом."
          }
        }
      }
    },
    "lab.rdw.name": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Red Cell Distribution Width"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Ширина распределения эритроцитов"
          }
        }
      }
    },
    "lab.rdw.shortName": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "RDW"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "RDW"
          }
        }
      }
    },
    "lab.rdw.about": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "RDW measures how much red blood cells vary in size, which helps evaluate anemia."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "RDW отражает степень различия эритроцитов по размеру, что помогает в оценке анемии."
          }
        }
      }
    },
    "lab.rdw.lowMeaning": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A low value is generally not a concern and simply indicates red cells that are uniform in size."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Низкое значение, как правило, не вызывает беспокойства и просто означает, что эритроциты однородны по размеру."
          }
        }
      }
    },
    "lab.rdw.highMeaning": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A high value means red cells vary more in size, which can be an early sign of iron, B12, or folate shortfalls. Consider reviewing with a clinician."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Высокое значение означает большую вариабельность размера эритроцитов, что может быть ранним признаком дефицита железа, B12 или фолиевой кислоты. Стоит обсудить это с врачом."
          }
        }
      }
    },
    "lab.neutrophilsPercent.name": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Neutrophils"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Нейтрофилы"
          }
        }
      }
    },
    "lab.neutrophilsPercent.shortName": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Neut %"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Нейт. %"
          }
        }
      }
    },
    "lab.neutrophilsPercent.about": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Neutrophils are the most common white blood cell and are a first responder to infection."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Нейтрофилы — самый многочисленный тип лейкоцитов, первыми реагирующий на инфекцию."
          }
        }
      }
    },
    "lab.neutrophilsPercent.lowMeaning": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A low percentage can follow some viral infections or certain medications. Discuss persistently low values with a clinician, especially with frequent infections."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Низкий процент может встречаться после некоторых вирусных инфекций или на фоне определённых препаратов. Стойко низкие значения, особенно при частых инфекциях, стоит обсудить с врачом."
          }
        }
      }
    },
    "lab.neutrophilsPercent.highMeaning": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A high percentage commonly reflects the body responding to bacterial infection, inflammation, or physical stress. Consider reviewing persistent elevation with a clinician."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Высокий процент обычно отражает реакцию организма на бактериальную инфекцию, воспаление или физический стресс. Стойкое повышение стоит обсудить с врачом."
          }
        }
      }
    },
    "lab.lymphocytesPercent.name": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Lymphocytes"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Лимфоциты"
          }
        }
      }
    },
    "lab.lymphocytesPercent.shortName": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Lymph %"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Лимф. %"
          }
        }
      }
    },
    "lab.lymphocytesPercent.about": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Lymphocytes are white blood cells central to the immune response, including against viruses."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Лимфоциты — лейкоциты, играющие центральную роль в иммунном ответе, в том числе против вирусов."
          }
        }
      }
    },
    "lab.lymphocytesPercent.lowMeaning": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A low percentage can occur with acute stress, certain infections, or medications. Discuss persistent values with a clinician."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Низкий процент может возникать при остром стрессе, некоторых инфекциях или на фоне приёма препаратов. Стойкие отклонения стоит обсудить с врачом."
          }
        }
      }
    },
    "lab.lymphocytesPercent.highMeaning": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A high percentage is often seen with viral infections and usually resolves as you recover. Consider reviewing persistent elevation with a clinician."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Высокий процент часто наблюдается при вирусных инфекциях и обычно нормализуется по мере выздоровления. Стойкое повышение стоит обсудить с врачом."
          }
        }
      }
    },
    "lab.totalCholesterol.name": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Total Cholesterol"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Общий холестерин"
          }
        }
      }
    },
    "lab.totalCholesterol.shortName": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "TC"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "ОХ"
          }
        }
      }
    },
    "lab.totalCholesterol.about": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Total cholesterol sums the cholesterol carried by all lipoprotein particles in your blood."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Общий холестерин — суммарное количество холестерина, переносимого всеми липопротеидными частицами крови."
          }
        }
      }
    },
    "lab.totalCholesterol.lowMeaning": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A low value is generally not a concern on its own and is usually considered favorable for heart health."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Низкое значение само по себе обычно не вызывает беспокойства и считается благоприятным для здоровья сердца."
          }
        }
      }
    },
    "lab.totalCholesterol.highMeaning": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A high value may relate to diet, activity level, genetics, or other conditions and can raise cardiovascular risk over time. Discuss elevated results with a clinician."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Высокое значение может быть связано с питанием, уровнем активности, генетикой или другими факторами и со временем повышать сердечно-сосудистый риск. Обсудите повышенные результаты с врачом."
          }
        }
      }
    },
    "lab.ldlCholesterol.name": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "LDL Cholesterol"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Холестерин ЛПНП"
          }
        }
      }
    },
    "lab.ldlCholesterol.shortName": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "LDL"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "ЛПНП"
          }
        }
      }
    },
    "lab.ldlCholesterol.about": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "LDL, sometimes called \"bad\" cholesterol, can contribute to plaque buildup in arteries."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "ЛПНП, иногда называемый «плохим» холестерином, может способствовать образованию бляшек в артериях."
          }
        }
      }
    },
    "lab.ldlCholesterol.lowMeaning": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A low value is generally desirable and associated with lower cardiovascular risk."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Низкое значение, как правило, благоприятно и связано с более низким сердечно-сосудистым риском."
          }
        }
      }
    },
    "lab.ldlCholesterol.highMeaning": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A high value can build up in artery walls and raise cardiovascular risk over time. Diet, activity, genetics, and other factors contribute; discuss elevated results with a clinician."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Высокое значение может накапливаться в стенках артерий и со временем повышать сердечно-сосудистый риск. Питание, физическая активность, генетика и другие факторы играют роль; обсудите повышенные результаты с врачом."
          }
        }
      }
    },
    "lab.hdlCholesterol.name": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "HDL Cholesterol"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Холестерин ЛПВП"
          }
        }
      }
    },
    "lab.hdlCholesterol.shortName": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "HDL"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "ЛПВП"
          }
        }
      }
    },
    "lab.hdlCholesterol.about": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "HDL, sometimes called \"good\" cholesterol, helps remove other cholesterol from the bloodstream."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "ЛПВП, иногда называемый «хорошим» холестерином, помогает выводить другой холестерин из кровотока."
          }
        }
      }
    },
    "lab.hdlCholesterol.lowMeaning": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A low value offers less protective benefit and is linked to higher cardiovascular risk. Regular activity and other habits can help; discuss with a clinician."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Низкое значение даёт меньше защитного эффекта и связано с более высоким сердечно-сосудистым риском. Помочь могут регулярная физическая активность и другие привычки; обсудите это с врачом."
          }
        }
      }
    },
    "lab.hdlCholesterol.highMeaning": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A higher value is generally considered protective for heart health."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Более высокое значение обычно считается защитным для здоровья сердца."
          }
        }
      }
    },
    "lab.triglycerides.name": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Triglycerides"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Триглицериды"
          }
        }
      }
    },
    "lab.triglycerides.shortName": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "TG"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "ТГ"
          }
        }
      }
    },
    "lab.triglycerides.about": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Triglycerides are a type of fat in the blood used and stored for energy."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Триглицериды — тип жиров в крови, используемых и запасаемых организмом для получения энергии."
          }
        }
      }
    },
    "lab.triglycerides.lowMeaning": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A low value is generally desirable."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Низкое значение, как правило, благоприятно."
          }
        }
      }
    },
    "lab.triglycerides.highMeaning": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A high value can relate to diet, alcohol, excess weight, uncontrolled blood sugar, or a recent non-fasting sample. Very high values warrant prompt discussion with a clinician."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Высокое значение может быть связано с питанием, алкоголем, избыточным весом, неконтролируемым уровнем сахара в крови или недавним приёмом пищи перед анализом. Очень высокие значения требуют скорейшего обсуждения с врачом."
          }
        }
      }
    },
    "lab.fastingGlucose.name": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Fasting Glucose"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Глюкоза натощак"
          }
        }
      }
    },
    "lab.fastingGlucose.shortName": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Glu"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Глю"
          }
        }
      }
    },
    "lab.fastingGlucose.about": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Fasting glucose measures blood sugar after not eating, typically for at least 8 hours."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Глюкоза натощак измеряет уровень сахара в крови после голодания, как правило не менее 8 часов."
          }
        }
      }
    },
    "lab.fastingGlucose.lowMeaning": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A low value can follow prolonged fasting, intense exercise, or certain medications, and may cause shakiness or lightheadedness. Frequent low readings deserve a clinician's attention."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Низкое значение может возникать после длительного голодания, интенсивных физических нагрузок или на фоне определённых препаратов и может вызывать дрожь или головокружение. Частые низкие показатели требуют внимания врача."
          }
        }
      }
    },
    "lab.fastingGlucose.highMeaning": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A high value can reflect a non-fasting sample, stress, or elevated blood sugar. Repeated high values should be reviewed with a clinician."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Высокое значение может отражать несоблюдение голодания перед анализом, стресс или повышенный уровень сахара в крови. Повторяющиеся высокие значения стоит обсудить с врачом."
          }
        }
      }
    },
    "lab.hba1c.name": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Hemoglobin A1c"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Гликированный гемоглобин"
          }
        }
      }
    },
    "lab.hba1c.shortName": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "HbA1c"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "HbA1c"
          }
        }
      }
    },
    "lab.hba1c.about": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "HbA1c estimates your average blood sugar over the past two to three months."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "HbA1c отражает средний уровень сахара в крови за последние два-три месяца."
          }
        }
      }
    },
    "lab.hba1c.lowMeaning": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A low value is uncommon and can occasionally relate to anemia or shortened red-cell lifespan. Discuss unusual results with a clinician."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Низкое значение встречается редко и иногда может быть связано с анемией или укороченной продолжительностью жизни эритроцитов. Необычные результаты стоит обсудить с врачом."
          }
        }
      }
    },
    "lab.hba1c.highMeaning": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A higher value reflects higher average blood sugar over recent months. Discuss elevated results with a clinician to understand next steps."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Более высокое значение отражает более высокий средний уровень сахара в крови за последние месяцы. Обсудите повышенные результаты с врачом, чтобы понять дальнейшие шаги."
          }
        }
      }
    },
    "lab.insulin.name": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Fasting Insulin"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Инсулин натощак"
          }
        }
      }
    },
    "lab.insulin.shortName": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Insulin"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Инсулин"
          }
        }
      }
    },
    "lab.insulin.about": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Insulin is the hormone that helps move sugar from the blood into cells for energy."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Инсулин — гормон, который помогает переносить сахар из крови в клетки для получения энергии."
          }
        }
      }
    },
    "lab.insulin.lowMeaning": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A low value can simply reflect fasting. Interpretation depends on your blood sugar at the same time; discuss with a clinician if you have questions."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Низкое значение может просто отражать состояние натощак. Интерпретация зависит от одновременного уровня сахара в крови; при возникновении вопросов обсудите это с врачом."
          }
        }
      }
    },
    "lab.insulin.highMeaning": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A high value can accompany insulin resistance and is often linked to excess weight or inactivity. Consider reviewing elevated results with a clinician."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Высокое значение может сопровождать инсулинорезистентность и часто связано с избыточным весом или низкой физической активностью. Обсудите повышенные результаты с врачом."
          }
        }
      }
    },
    "lab.sodium.name": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Sodium"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Натрий"
          }
        }
      }
    },
    "lab.sodium.shortName": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Na"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Na"
          }
        }
      }
    },
    "lab.sodium.about": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Sodium is an electrolyte that helps regulate fluid balance and nerve and muscle function."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Натрий — электролит, регулирующий водный баланс и функцию нервов и мышц."
          }
        }
      }
    },
    "lab.sodium.lowMeaning": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A low value can follow excess fluid intake, certain medications, or fluid loss. Marked or symptomatic changes should be evaluated promptly by a clinician."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Низкое значение может возникать при избыточном потреблении жидкости, на фоне определённых препаратов или при потере жидкости. Выраженные или сопровождающиеся симптомами изменения требуют скорейшей оценки врачом."
          }
        }
      }
    },
    "lab.sodium.highMeaning": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A high value most often reflects dehydration or insufficient water intake. Persistent or marked elevation warrants a clinician's review."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Высокое значение чаще всего отражает обезвоживание или недостаточное потребление воды. Стойкое или выраженное повышение требует консультации врача."
          }
        }
      }
    },
    "lab.potassium.name": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Potassium"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Калий"
          }
        }
      }
    },
    "lab.potassium.shortName": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "K"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "K"
          }
        }
      }
    },
    "lab.potassium.about": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Potassium is an electrolyte essential for nerve signals, muscle function, and heart rhythm."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Калий — электролит, необходимый для нервной передачи, работы мышц и сердечного ритма."
          }
        }
      }
    },
    "lab.potassium.lowMeaning": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A low value can result from fluid loss, certain diuretics, or vomiting and may affect muscles and heart rhythm. Notable lows should be discussed promptly with a clinician."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Низкое значение может быть результатом потери жидкости, приёма некоторых диуретиков или рвоты и может влиять на мышцы и сердечный ритм. Заметно низкие значения стоит скорее обсудить с врачом."
          }
        }
      }
    },
    "lab.potassium.highMeaning": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A high value can relate to kidney function, medications, or a sample handling artifact. Genuine elevation should be reviewed promptly by a clinician."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Высокое значение может быть связано с функцией почек, приёмом препаратов или артефактом при обработке образца. Истинное повышение требует скорейшей консультации врача."
          }
        }
      }
    },
    "lab.chloride.name": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Chloride"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Хлор"
          }
        }
      }
    },
    "lab.chloride.shortName": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Cl"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Cl"
          }
        }
      }
    },
    "lab.chloride.about": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Chloride is an electrolyte that works with sodium to maintain fluid and acid-base balance."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Хлор — электролит, который вместе с натрием поддерживает водный и кислотно-щелочной баланс."
          }
        }
      }
    },
    "lab.chloride.lowMeaning": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A low value can accompany vomiting, certain medications, or fluid shifts. It is usually interpreted alongside other electrolytes; discuss with a clinician if it persists."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Низкое значение может сопровождать рвоту, приём определённых препаратов или перераспределение жидкости. Обычно оценивается вместе с другими электролитами; если сохраняется, обсудите это с врачом."
          }
        }
      }
    },
    "lab.chloride.highMeaning": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A high value can relate to dehydration or acid-base balance. It is typically reviewed with other electrolytes; consider discussing persistent values with a clinician."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Высокое значение может быть связано с обезвоживанием или кислотно-щелочным балансом. Обычно оценивается вместе с другими электролитами; стойкие отклонения стоит обсудить с врачом."
          }
        }
      }
    },
    "lab.calcium.name": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Calcium"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Кальций"
          }
        }
      }
    },
    "lab.calcium.shortName": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Ca"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Ca"
          }
        }
      }
    },
    "lab.calcium.about": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Calcium supports bones, nerve signaling, muscle function, and blood clotting."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Кальций поддерживает кости, нервную передачу, работу мышц и свёртывание крови."
          }
        }
      }
    },
    "lab.calcium.lowMeaning": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A low value can relate to low vitamin D, low albumin, or parathyroid or kidney factors. Discuss notable or symptomatic lows with a clinician."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Низкое значение может быть связано с дефицитом витамина D, низким уровнем альбумина или нарушениями функции паращитовидных желёз или почек. Заметное или сопровождающееся симптомами снижение стоит обсудить с врачом."
          }
        }
      }
    },
    "lab.calcium.highMeaning": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A high value can involve parathyroid activity, certain medications, or dehydration. Persistent elevation should be reviewed with a clinician."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Высокое значение может быть связано с активностью паращитовидных желёз, приёмом определённых препаратов или обезвоживанием. Стойкое повышение стоит обсудить с врачом."
          }
        }
      }
    },
    "lab.magnesium.name": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Magnesium"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Магний"
          }
        }
      }
    },
    "lab.magnesium.shortName": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Mg"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Mg"
          }
        }
      }
    },
    "lab.magnesium.about": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Magnesium is a mineral involved in hundreds of processes, including muscle and nerve function."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Магний — минерал, участвующий в сотнях процессов организма, включая работу мышц и нервной системы."
          }
        }
      }
    },
    "lab.magnesium.lowMeaning": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A low value can follow poor intake, alcohol use, certain medications, or digestive losses and may cause cramps. Discuss notable lows with a clinician."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Низкое значение может возникать при недостаточном потреблении, употреблении алкоголя, приёме определённых препаратов или потерях через пищеварительную систему и может вызывать судороги. Заметное снижение стоит обсудить с врачом."
          }
        }
      }
    },
    "lab.magnesium.highMeaning": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A high value is uncommon and is most often related to kidney function or magnesium-containing supplements. Consider reviewing with a clinician."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Высокое значение встречается редко и чаще всего связано с функцией почек или приёмом магнийсодержащих добавок. Стоит обсудить это с врачом."
          }
        }
      }
    },
    "lab.phosphorus.name": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Phosphorus"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Фосфор"
          }
        }
      }
    },
    "lab.phosphorus.shortName": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Phos"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "P"
          }
        }
      }
    },
    "lab.phosphorus.about": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Phosphorus works with calcium to build bones and support energy metabolism."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Фосфор вместе с кальцием участвует в формировании костей и поддержании энергетического обмена."
          }
        }
      }
    },
    "lab.phosphorus.lowMeaning": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A low value can relate to nutrition, certain medications, or vitamin D status. Discuss persistent lows with a clinician."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Низкое значение может быть связано с питанием, приёмом определённых препаратов или уровнем витамина D. Стойкое снижение стоит обсудить с врачом."
          }
        }
      }
    },
    "lab.phosphorus.highMeaning": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A high value is often linked to kidney function. It is usually reviewed alongside calcium; consider discussing persistent elevation with a clinician."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Высокое значение часто связано с функцией почек. Обычно оценивается вместе с кальцием; стойкое повышение стоит обсудить с врачом."
          }
        }
      }
    },
    "lab.creatinine.name": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Creatinine"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Креатинин"
          }
        }
      }
    },
    "lab.creatinine.shortName": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Cr"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Cr"
          }
        }
      }
    },
    "lab.creatinine.about": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Creatinine is a waste product from muscle activity that the kidneys filter out."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Креатинин — продукт распада, образующийся в мышцах, который фильтруется почками."
          }
        }
      }
    },
    "lab.creatinine.lowMeaning": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A low value can reflect lower muscle mass and is usually not a concern on its own."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Низкое значение может отражать сниженную мышечную массу и само по себе обычно не вызывает беспокойства."
          }
        }
      }
    },
    "lab.creatinine.highMeaning": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A high value can relate to reduced kidney filtering, dehydration, high muscle mass, or a recent high-protein meal. Discuss persistent elevation with a clinician."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Высокое значение может быть связано со снижением фильтрационной функции почек, обезвоживанием, высокой мышечной массой или недавним приёмом пищи с высоким содержанием белка. Стойкое повышение стоит обсудить с врачом."
          }
        }
      }
    },
    "lab.bun.name": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Blood Urea Nitrogen"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Азот мочевины крови"
          }
        }
      }
    },
    "lab.bun.shortName": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "BUN"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "BUN"
          }
        }
      }
    },
    "lab.bun.about": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "BUN measures the amount of nitrogen from urea, a waste product the kidneys remove."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "BUN измеряет количество азота, содержащегося в мочевине — продукте распада, который удаляют почки."
          }
        }
      }
    },
    "lab.bun.lowMeaning": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A low value can accompany a low-protein diet, overhydration, or liver factors and is usually not concerning on its own."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Низкое значение может сопровождать низкобелковую диету, избыточную гидратацию или особенности работы печени и само по себе обычно не вызывает беспокойства."
          }
        }
      }
    },
    "lab.bun.highMeaning": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A high value can relate to dehydration, a high-protein diet, or kidney function. It is usually interpreted with creatinine; discuss persistent elevation with a clinician."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Высокое значение может быть связано с обезвоживанием, высокобелковой диетой или функцией почек. Обычно оценивается вместе с креатинином; стойкое повышение стоит обсудить с врачом."
          }
        }
      }
    },
    "lab.egfr.name": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Estimated GFR"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Расчётная скорость клубочковой фильтрации"
          }
        }
      }
    },
    "lab.egfr.shortName": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "eGFR"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "СКФ"
          }
        }
      }
    },
    "lab.egfr.about": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "eGFR estimates how well your kidneys filter waste, calculated from creatinine and other factors."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "СКФ оценивает, насколько эффективно почки фильтруют отходы; рассчитывается на основе креатинина и других факторов."
          }
        }
      }
    },
    "lab.egfr.lowMeaning": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A lower value suggests the kidneys are filtering more slowly, which can occur with age, dehydration, or kidney conditions. Discuss persistently low results with a clinician."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Более низкое значение указывает на замедленную фильтрацию почек, что может быть связано с возрастом, обезвоживанием или заболеваниями почек. Стойко низкие результаты стоит обсудить с врачом."
          }
        }
      }
    },
    "lab.egfr.highMeaning": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A higher value generally indicates strong kidney filtering and is not a concern."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Более высокое значение, как правило, указывает на хорошую фильтрационную функцию почек и не вызывает беспокойства."
          }
        }
      }
    },
    "lab.uricAcid.name": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Uric Acid"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Мочевая кислота"
          }
        }
      }
    },
    "lab.uricAcid.shortName": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "UA"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "МК"
          }
        }
      }
    },
    "lab.uricAcid.about": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Uric acid is a waste product from the breakdown of purines found in some foods and body cells."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Мочевая кислота — продукт распада пуринов, содержащихся в некоторых продуктах питания и клетках организма."
          }
        }
      }
    },
    "lab.uricAcid.lowMeaning": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A low value is usually not a concern and can relate to certain medications or diet."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Низкое значение обычно не вызывает беспокойства и может быть связано с приёмом определённых препаратов или питанием."
          }
        }
      }
    },
    "lab.uricAcid.highMeaning": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A high value can be influenced by diet, alcohol, dehydration, or genetics and is associated with gout. Discuss persistent elevation, especially with joint pain, with a clinician."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Высокое значение может зависеть от питания, алкоголя, обезвоживания или генетики и связано с подагрой. Стойкое повышение, особенно при боли в суставах, стоит обсудить с врачом."
          }
        }
      }
    },
    "lab.alt.name": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Alanine Aminotransferase"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Аланинаминотрансфераза"
          }
        }
      }
    },
    "lab.alt.shortName": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "ALT"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "АЛТ"
          }
        }
      }
    },
    "lab.alt.about": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "ALT is an enzyme found mainly in the liver; levels rise when liver cells are stressed."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "АЛТ — фермент, содержащийся преимущественно в печени; его уровень повышается при повреждении клеток печени."
          }
        }
      }
    },
    "lab.alt.lowMeaning": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A low value is generally not a concern."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Низкое значение обычно не вызывает беспокойства."
          }
        }
      }
    },
    "lab.alt.highMeaning": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A high value can follow alcohol, certain medications, fatty liver, recent intense exercise, or infection. Discuss persistent elevation with a clinician."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Высокое значение может быть связано с приёмом алкоголя, определённых препаратов, жировым гепатозом, недавней интенсивной физической нагрузкой или инфекцией. Стойкое повышение стоит обсудить с врачом."
          }
        }
      }
    },
    "lab.ast.name": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Aspartate Aminotransferase"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Аспартатаминотрансфераза"
          }
        }
      }
    },
    "lab.ast.shortName": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "AST"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "АСТ"
          }
        }
      }
    },
    "lab.ast.about": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "AST is an enzyme found in the liver and muscles; it is used alongside ALT to assess the liver."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "АСТ — фермент, содержащийся в печени и мышцах; используется вместе с АЛТ для оценки состояния печени."
          }
        }
      }
    },
    "lab.ast.lowMeaning": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A low value is generally not a concern."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Низкое значение обычно не вызывает беспокойства."
          }
        }
      }
    },
    "lab.ast.highMeaning": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A high value can relate to the liver but also to muscle activity, since AST is found in muscle too. Recent exercise, medications, or alcohol may contribute; discuss persistent elevation with a clinician."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Высокое значение может быть связано с печенью, но также и с мышечной активностью, поскольку АСТ содержится и в мышцах. Причиной могут быть недавняя физическая нагрузка, приём препаратов или алкоголь; стойкое повышение стоит обсудить с врачом."
          }
        }
      }
    },
    "lab.alp.name": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Alkaline Phosphatase"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Щелочная фосфатаза"
          }
        }
      }
    },
    "lab.alp.shortName": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "ALP"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "ЩФ"
          }
        }
      }
    },
    "lab.alp.about": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "ALP is an enzyme found in the liver, bile ducts, and bone."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "ЩФ — фермент, содержащийся в печени, жёлчных протоках и костной ткани."
          }
        }
      }
    },
    "lab.alp.lowMeaning": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A low value is uncommon and can occasionally relate to nutrition or certain conditions. Discuss unusual results with a clinician."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Низкое значение встречается редко и иногда может быть связано с питанием или определёнными состояниями. Необычные результаты стоит обсудить с врачом."
          }
        }
      }
    },
    "lab.alp.highMeaning": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A high value can involve the liver, bile ducts, or bone, and is normal during growth or pregnancy. Discuss persistent elevation with a clinician."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Высокое значение может быть связано с печенью, жёлчными протоками или костной тканью, а также является нормой в период роста или беременности. Стойкое повышение стоит обсудить с врачом."
          }
        }
      }
    },
    "lab.ggt.name": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Gamma-Glutamyl Transferase"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Гамма-глутамилтрансфераза"
          }
        }
      }
    },
    "lab.ggt.shortName": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "GGT"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "ГГТ"
          }
        }
      }
    },
    "lab.ggt.about": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "GGT is a liver enzyme that helps pinpoint whether raised liver values stem from the bile ducts."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "ГГТ — печёночный фермент, который помогает определить, связано ли повышение печёночных показателей с жёлчными протоками."
          }
        }
      }
    },
    "lab.ggt.lowMeaning": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A low value is generally not a concern."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Низкое значение обычно не вызывает беспокойства."
          }
        }
      }
    },
    "lab.ggt.highMeaning": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A high value can relate to alcohol use, certain medications, or bile-duct issues. It helps clarify the source of a raised ALP; discuss persistent elevation with a clinician."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Высокое значение может быть связано с употреблением алкоголя, приёмом определённых препаратов или нарушениями жёлчных протоков. Помогает уточнить причину повышения ЩФ; стойкое повышение стоит обсудить с врачом."
          }
        }
      }
    },
    "lab.totalBilirubin.name": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Total Bilirubin"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Общий билирубин"
          }
        }
      }
    },
    "lab.totalBilirubin.shortName": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "T. Bili"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Билирубин"
          }
        }
      }
    },
    "lab.totalBilirubin.about": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Bilirubin is a yellow pigment made when red blood cells break down and is processed by the liver."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Билирубин — жёлтый пигмент, образующийся при распаде эритроцитов и перерабатываемый печенью."
          }
        }
      }
    },
    "lab.totalBilirubin.lowMeaning": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A low value is generally not a concern."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Низкое значение обычно не вызывает беспокойства."
          }
        }
      }
    },
    "lab.totalBilirubin.highMeaning": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A high value can cause yellowing of the skin or eyes and may relate to the liver, bile flow, red-cell breakdown, or a benign inherited pattern (Gilbert syndrome). Discuss elevation with a clinician."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Высокое значение может вызывать желтизну кожи или глаз и может быть связано с печенью, оттоком жёлчи, распадом эритроцитов или доброкачественной наследственной особенностью (синдром Жильбера). Обсудите повышение с врачом."
          }
        }
      }
    },
    "lab.albumin.name": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Albumin"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Альбумин"
          }
        }
      }
    },
    "lab.albumin.shortName": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Alb"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Альб"
          }
        }
      }
    },
    "lab.albumin.about": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Albumin is a protein made by the liver that helps keep fluid in blood vessels and carries substances."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Альбумин — белок, вырабатываемый печенью, который удерживает жидкость в сосудах и переносит различные вещества."
          }
        }
      }
    },
    "lab.albumin.lowMeaning": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A low value can relate to nutrition, inflammation, or liver or kidney factors. Discuss persistent lows with a clinician."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Низкое значение может быть связано с питанием, воспалением или особенностями работы печени или почек. Стойкое снижение стоит обсудить с врачом."
          }
        }
      }
    },
    "lab.albumin.highMeaning": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A high value is most often caused by dehydration. Rehydrating usually resolves it; discuss persistent elevation with a clinician."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Высокое значение чаще всего вызвано обезвоживанием. Обычно нормализуется после восполнения жидкости; стойкое повышение стоит обсудить с врачом."
          }
        }
      }
    },
    "lab.totalProtein.name": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Total Protein"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Общий белок"
          }
        }
      }
    },
    "lab.totalProtein.shortName": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "TP"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Белок"
          }
        }
      }
    },
    "lab.totalProtein.about": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Total protein measures albumin and globulins together, reflecting overall protein in the blood."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Общий белок измеряет альбумин и глобулины вместе, отражая суммарное содержание белка в крови."
          }
        }
      }
    },
    "lab.totalProtein.lowMeaning": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A low value can relate to nutrition, or liver or kidney factors. Discuss persistent lows with a clinician."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Низкое значение может быть связано с питанием или особенностями работы печени или почек. Стойкое снижение стоит обсудить с врачом."
          }
        }
      }
    },
    "lab.totalProtein.highMeaning": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A high value can reflect dehydration or ongoing inflammation. Consider reviewing persistent elevation with a clinician."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Высокое значение может отражать обезвоживание или текущее воспаление. Стойкое повышение стоит обсудить с врачом."
          }
        }
      }
    },
    "lab.tsh.name": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Thyroid-Stimulating Hormone"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Тиреотропный гормон"
          }
        }
      }
    },
    "lab.tsh.shortName": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "TSH"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "ТТГ"
          }
        }
      }
    },
    "lab.tsh.about": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "TSH is a pituitary hormone that signals the thyroid; it is the primary screen for thyroid function."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "ТТГ — гормон гипофиза, регулирующий работу щитовидной железы; основной показатель для оценки её функции."
          }
        }
      }
    },
    "lab.tsh.lowMeaning": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A low value can suggest an overactive thyroid, since the body signals less. Certain medications also affect it; discuss with a clinician, often with free T4."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Низкое значение может указывать на повышенную функцию щитовидной железы, поскольку организм снижает сигнал. На него также влияют некоторые препараты; обсудите это с врачом, как правило вместе со свободным T4."
          }
        }
      }
    },
    "lab.tsh.highMeaning": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A high value can suggest an underactive thyroid, as the body signals harder for hormone. Discuss elevated results with a clinician, usually alongside free T4."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Высокое значение может указывать на пониженную функцию щитовидной железы, поскольку организм усиливает сигнал для выработки гормона. Обсудите повышенные результаты с врачом, обычно вместе со свободным T4."
          }
        }
      }
    },
    "lab.freeT4.name": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Free Thyroxine"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Свободный тироксин"
          }
        }
      }
    },
    "lab.freeT4.shortName": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "FT4"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Т4 своб."
          }
        }
      }
    },
    "lab.freeT4.about": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Free T4 is the active, unbound form of the main thyroid hormone circulating in the blood."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Свободный T4 — активная, не связанная с белками форма основного гормона щитовидной железы, циркулирующего в крови."
          }
        }
      }
    },
    "lab.freeT4.lowMeaning": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A low value can accompany an underactive thyroid and is interpreted together with TSH. Discuss with a clinician."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Низкое значение может сопровождать пониженную функцию щитовидной железы и оценивается вместе с ТТГ. Обсудите это с врачом."
          }
        }
      }
    },
    "lab.freeT4.highMeaning": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A high value can accompany an overactive thyroid and is interpreted together with TSH. Discuss with a clinician."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Высокое значение может сопровождать повышенную функцию щитовидной железы и оценивается вместе с ТТГ. Обсудите это с врачом."
          }
        }
      }
    },
    "lab.freeT3.name": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Free Triiodothyronine"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Свободный трийодтиронин"
          }
        }
      }
    },
    "lab.freeT3.shortName": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "FT3"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Т3 своб."
          }
        }
      }
    },
    "lab.freeT3.about": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Free T3 is the active form of the more potent thyroid hormone and helps assess thyroid function."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Свободный T3 — активная форма более сильного гормона щитовидной железы, помогающая оценить её функцию."
          }
        }
      }
    },
    "lab.freeT3.lowMeaning": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A low value can occur with an underactive thyroid or during other illness. It is interpreted with TSH and free T4; discuss with a clinician."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Низкое значение может возникать при пониженной функции щитовидной железы или на фоне других заболеваний. Оценивается вместе с ТТГ и свободным T4; обсудите это с врачом."
          }
        }
      }
    },
    "lab.freeT3.highMeaning": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A high value can occur with an overactive thyroid. It is interpreted alongside TSH and free T4; discuss with a clinician."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Высокое значение может возникать при повышенной функции щитовидной железы. Оценивается вместе с ТТГ и свободным T4; обсудите это с врачом."
          }
        }
      }
    },
    "lab.vitaminD.name": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Vitamin D, 25-Hydroxy"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Витамин D, 25-гидрокси"
          }
        }
      }
    },
    "lab.vitaminD.shortName": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Vit D"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Вит. D"
          }
        }
      }
    },
    "lab.vitaminD.about": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This measures your body's vitamin D stores, important for bone health and calcium absorption."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Показатель отражает запасы витамина D в организме, важные для здоровья костей и усвоения кальция."
          }
        }
      }
    },
    "lab.vitaminD.lowMeaning": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A low value is common, especially with limited sun exposure, and can affect bone health. Diet, sunlight, or supplements may help; discuss with a clinician."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Низкое значение встречается часто, особенно при недостатке солнечного света, и может влиять на здоровье костей. Помочь могут питание, солнечный свет или добавки; обсудите это с врачом."
          }
        }
      }
    },
    "lab.vitaminD.highMeaning": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A high value usually results from taking high-dose supplements. Very high values can affect calcium; review supplement use with a clinician."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Высокое значение обычно связано с приёмом высоких доз добавок. Очень высокие значения могут влиять на уровень кальция; обсудите приём добавок с врачом."
          }
        }
      }
    },
    "lab.vitaminB12.name": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Vitamin B12"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Витамин B12"
          }
        }
      }
    },
    "lab.vitaminB12.shortName": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "B12"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "B12"
          }
        }
      }
    },
    "lab.vitaminB12.about": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Vitamin B12 supports nerve function and the formation of red blood cells."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Витамин B12 поддерживает функцию нервной системы и образование эритроцитов."
          }
        }
      }
    },
    "lab.vitaminB12.lowMeaning": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A low value can relate to diet (such as a plant-based diet), absorption, or certain medications, and may affect energy and nerves. Discuss persistent lows with a clinician."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Низкое значение может быть связано с питанием (например, растительным рационом), усвоением или приёмом определённых препаратов и может влиять на уровень энергии и нервную систему. Стойкое снижение стоит обсудить с врачом."
          }
        }
      }
    },
    "lab.vitaminB12.highMeaning": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A high value often reflects supplement intake and is usually not concerning. Consider reviewing unexplained elevation with a clinician."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Высокое значение часто отражает приём добавок и обычно не вызывает беспокойства. Необъяснимое повышение стоит обсудить с врачом."
          }
        }
      }
    },
    "lab.folate.name": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Folate"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Фолиевая кислота"
          }
        }
      }
    },
    "lab.folate.shortName": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Folate"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Фолат"
          }
        }
      }
    },
    "lab.folate.about": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Folate (vitamin B9) is needed to make DNA and red blood cells and is important in pregnancy."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Фолиевая кислота (витамин B9) необходима для синтеза ДНК и образования эритроцитов и особенно важна во время беременности."
          }
        }
      }
    },
    "lab.folate.lowMeaning": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A low value can relate to diet or absorption and may affect red-cell formation. Folate-rich foods or supplements may help; discuss with a clinician."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Низкое значение может быть связано с питанием или усвоением и может влиять на образование эритроцитов. Помочь могут продукты, богатые фолиевой кислотой, или добавки; обсудите это с врачом."
          }
        }
      }
    },
    "lab.folate.highMeaning": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A high value is usually harmless and often reflects supplements or fortified foods."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Высокое значение обычно безвредно и часто отражает приём добавок или обогащённых продуктов."
          }
        }
      }
    },
    "lab.ferritin.name": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Ferritin"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Ферритин"
          }
        }
      }
    },
    "lab.ferritin.shortName": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Ferritin"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Ферритин"
          }
        }
      }
    },
    "lab.ferritin.about": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Ferritin reflects the amount of iron your body has in storage."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Ферритин отражает количество железа, накопленного в организме."
          }
        }
      }
    },
    "lab.ferritin.lowMeaning": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A low value is a sensitive sign of low iron stores and can accompany fatigue. Diet or iron supplements may help; discuss with a clinician."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Низкое значение — чувствительный признак дефицита запасов железа и может сопровождаться усталостью. Помочь могут питание или препараты железа; обсудите это с врачом."
          }
        }
      }
    },
    "lab.ferritin.highMeaning": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A high value can reflect iron overload but also rises with inflammation or infection. Discuss persistent elevation with a clinician."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Высокое значение может отражать избыток железа, но также повышается при воспалении или инфекции. Стойкое повышение стоит обсудить с врачом."
          }
        }
      }
    },
    "lab.iron.name": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Serum Iron"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Железо сыворотки"
          }
        }
      }
    },
    "lab.iron.shortName": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Iron"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Fe"
          }
        }
      }
    },
    "lab.iron.about": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Serum iron measures the amount of iron circulating in the blood at the time of the test."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Железо сыворотки измеряет количество железа, циркулирующего в крови на момент анализа."
          }
        }
      }
    },
    "lab.iron.lowMeaning": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A low value can accompany iron deficiency or blood loss and varies through the day. It is interpreted with ferritin and TIBC; discuss with a clinician."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Низкое значение может сопровождать дефицит железа или кровопотерю и меняется в течение дня. Оценивается вместе с ферритином и ОЖСС; обсудите это с врачом."
          }
        }
      }
    },
    "lab.iron.highMeaning": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A high value can follow iron supplements, a recent iron-rich meal, or iron overload. Consider reviewing persistent elevation with a clinician."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Высокое значение может быть связано с приёмом препаратов железа, недавним приёмом богатой железом пищи или избытком железа. Стойкое повышение стоит обсудить с врачом."
          }
        }
      }
    },
    "lab.tibc.name": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Total Iron-Binding Capacity"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Общая железосвязывающая способность"
          }
        }
      }
    },
    "lab.tibc.shortName": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "TIBC"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "ОЖСС"
          }
        }
      }
    },
    "lab.tibc.about": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "TIBC measures the blood's total capacity to bind and transport iron, reflecting iron status."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "ОЖСС измеряет общую способность крови связывать и переносить железо, отражая статус обмена железа."
          }
        }
      }
    },
    "lab.tibc.lowMeaning": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A low value can be seen with inflammation or iron overload. It is interpreted with iron and ferritin; discuss with a clinician if needed."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Низкое значение может встречаться при воспалении или избытке железа. Оценивается вместе с железом сыворотки и ферритином; при необходимости обсудите это с врачом."
          }
        }
      }
    },
    "lab.tibc.highMeaning": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A high value often accompanies iron deficiency, as the blood has more capacity to carry iron. Discuss with a clinician alongside iron and ferritin."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Высокое значение часто сопровождает дефицит железа, поскольку у крови остаётся больше свободной способности переносить железо. Обсудите это с врачом вместе с показателями железа и ферритина."
          }
        }
      }
    },
    "lab.crp.name": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "C-Reactive Protein"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "С-реактивный белок"
          }
        }
      }
    },
    "lab.crp.shortName": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "CRP"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "СРБ"
          }
        }
      }
    },
    "lab.crp.about": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "CRP is a protein made by the liver that rises when there is inflammation in the body."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "СРБ — белок, вырабатываемый печенью, уровень которого повышается при наличии воспаления в организме."
          }
        }
      }
    },
    "lab.crp.lowMeaning": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A low value is generally desirable and suggests little active inflammation."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Низкое значение, как правило, благоприятно и указывает на незначительную активность воспаления."
          }
        }
      }
    },
    "lab.crp.highMeaning": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A high value signals inflammation, which can follow infection, injury, or a chronic condition, and rises temporarily with minor illness. Discuss persistent elevation with a clinician."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Высокое значение сигнализирует о воспалении, которое может быть связано с инфекцией, травмой или хроническим заболеванием, а также временно повышается при лёгких недомоганиях. Стойкое повышение стоит обсудить с врачом."
          }
        }
      }
    },
    "lab.esr.name": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Erythrocyte Sedimentation Rate"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Скорость оседания эритроцитов"
          }
        }
      }
    },
    "lab.esr.shortName": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "ESR"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "СОЭ"
          }
        }
      }
    },
    "lab.esr.about": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "ESR measures how quickly red blood cells settle, an indirect and general marker of inflammation."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "СОЭ измеряет скорость оседания эритроцитов — косвенный и неспецифический маркер воспаления."
          }
        }
      }
    },
    "lab.esr.lowMeaning": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A low value is generally not a concern."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Низкое значение обычно не вызывает беспокойства."
          }
        }
      }
    },
    "lab.esr.highMeaning": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A high value is a nonspecific sign of inflammation and can rise with infection, age, anemia, or pregnancy. Discuss persistent elevation with a clinician."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Высокое значение — неспецифический признак воспаления и может повышаться при инфекции, с возрастом, при анемии или беременности. Стойкое повышение стоит обсудить с врачом."
          }
        }
      }
    }
  },
  "version": "1.0"
}
