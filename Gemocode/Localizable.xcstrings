    },
    "The rules for using Gemocode, including its educational (not medical) nature and how Premium billing works.": {
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Правила использования Gemocode, включая его образовательный (не медицинский) характер и порядок оплаты подписки Premium."
          }
        }
      }
    },
    "Then": {
      "localizations": {
        "ru": {
