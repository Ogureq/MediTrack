        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Все %1$lld целей будут проверены на заборе %2$@ — дополнительные анализы не нужны."
          }
        }
      }
    },
    "Allergies": {
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Аллергии"
          }
        }
