      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Вложения"
          }
        }
      }
    },
    "Attachments — scanned photos and PDFs of your reports — are never transmitted anywhere by the app itself.": {
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Вложения — сканы и PDF-файлы ваших отчётов — никогда не передаются приложением никуда."
