        }
      }
    },
    "Track your medical reports, lab results, vitals and medications — and get a detailed review of your health data. Everything stays on your device.": {
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Ведите медицинские отчёты, результаты анализов, показатели и лекарства — и получайте подробный обзор здоровья. Все данные хранятся только на вашем устройстве."
          }
        }
      }
    },
    "Tracked privately, on-device": {
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Приватно отслеживается на устройстве"
          }
