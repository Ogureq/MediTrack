          "stringUnit": {
            "state": "translated",
            "value": "Вы останетесь в системе, пока не нажмёте «Заблокировать сейчас» или не отключите эту функцию. Данные остаются на этом устройстве."
          }
        }
      }
    },
    "You're caught up": {
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Все анализы сданы вовремя"
          }
